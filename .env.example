# ─── LiveKit Server ───────────────────────────────────────────────
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret_change_me_in_production

# Internal URL (agent → livekit-server inside Docker network)
LIVEKIT_URL=ws://livekit-server:7880

# External URL (iPhone → livekit-server over LAN / Tailscale)
# Replace with your host machine's IP or Tailscale IP
LIVEKIT_EXTERNAL_URL=ws://192.168.1.100:7880

# ─── Ollama ───────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL=llama3.1:8b

# ─── faster-whisper (STT) ────────────────────────────────────────
WHISPER_BASE_URL=http://whisper:8000/v1
WHISPER_MODEL=Systran/faster-whisper-large-v3

# ─── Kokoro (TTS) ────────────────────────────────────────────────
KOKORO_BASE_URL=http://kokoro:8880/v1
KOKORO_MODEL=kokoro
KOKORO_VOICE=af_heart
